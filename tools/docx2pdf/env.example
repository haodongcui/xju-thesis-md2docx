# Copy the variables you need into your shell startup file, or source a local copy:
#
#   cp tools/docx2pdf/env.example tools/docx2pdf/.env
#   set -a
#   . tools/docx2pdf/.env
#   set +a
#
# This file is an example only. The scripts do not load it automatically.

# Default DOCX to PDF backend: word, libreoffice, lo, or auto.
# XJU_DOCX2PDF_BACKEND=word

# Word backend
#
# No Microsoft Word executable path is required. The Word backend starts Word
# through the Windows COM registration name "Word.Application".
#
# Optional Windows-local temporary root. Use this only if the default Windows
# temp directory is unsuitable. It may be a WSL path under /mnt/<drive>/... or
# a Windows path such as C:\Temp\xju-word-docx2pdf.
# XJU_WORD_DOCX2PDF_TMP_ROOT=/mnt/c/Temp/xju-word-docx2pdf
# On native Windows PowerShell, use:
# $env:XJU_WORD_DOCX2PDF_TMP_ROOT = "C:\Temp\xju-word-docx2pdf"
#
# Optional override for the bundled VBS template.
# XJU_WORD_DOCX2PDF_VBS_TEMPLATE=/path/to/word_export.vbs
#
# Debug and behavior flags.
# XJU_WORD_DOCX2PDF_KEEP_TMP=1
# XJU_WORD_DOCX2PDF_SKIP_WORD_CHECK=1
# XJU_WORD_DOCX2PDF_UPDATE_FIELDS=0

# LibreOffice backend
#
# Optional LibreOffice executable path. Usually not needed when libreoffice or
# soffice is already in PATH.
# XJU_LIBREOFFICE_BIN=/usr/bin/libreoffice
# On native Windows PowerShell, use:
# $env:XJU_LIBREOFFICE_BIN = "C:\Program Files\LibreOffice\program\soffice.exe"
#
# Optional temporary root.
# XJU_LIBREOFFICE_DOCX2PDF_TMP_ROOT=/tmp/xju_libreoffice_docx2pdf
#
# Debug and behavior flags.
# XJU_LIBREOFFICE_DOCX2PDF_KEEP_TMP=1
# XJU_LIBREOFFICE_DOCX2PDF_UPDATE_FIELDS=0
